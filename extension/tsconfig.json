{
  "compilerOptions": {
    "target": "ES2022",
    "module": "NodeNext",
    "moduleResolution": "NodeNext",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "outDir": "dist",
    "rootDir": ".",
    "declaration": false,
    "noEmitOnError": false,
    "preserveSymlinks": true,
    "sourceMap": true,
    "resolveJsonModule": true
  },
  "include": ["owui-tools.ts"]
}
