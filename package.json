{
  "name": "pi-owui-bridge",
  "version": "0.1.0",
  "description": "Communication layer between Open WebUI and a per-(user, chat) pi-coding-agent subprocess running --mode rpc. The bridge owns HTTP/RPC translation; the agent loop, tools, skills, overlay, and compaction all live in Pi.",
  "type": "module",
  "private": true,
  "bin": { "pi-owui-bridge": "dist/server.js" },
  "scripts": {
    "build": "tsc -p tsconfig.json && tsc -p extension/tsconfig.json",
    "build:bridge": "tsc -p tsconfig.json",
    "build:extension": "tsc -p extension/tsconfig.json",
    "start": "node dist/server.js",
    "dev": "node --import tsx src/server.ts",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "file:../pi/packages/agent",
    "@earendil-works/pi-ai": "file:../pi/packages/ai",
    "@sinclair/typebox": "^0.34.0",
    "express": "^4.19.2",
    "undici": "^6.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
