{
  "name": "pi-owui-bridge",
  "version": "0.1.0",
  "description": "TypeScript service that fronts Open WebUI with an OpenAI-compatible agent loop and dispatches tool calls back to OWUI's HTTP tool service. Phase 1 runs its own loop; Phase 2 will swap it for @earendil-works/pi-agent-core's AgentHarness.",
  "type": "module",
  "private": true,
  "bin": { "pi-owui-bridge": "dist/server.js" },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/server.js",
    "dev": "node --import tsx src/server.ts",
    "test": "vitest --run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@earendil-works/pi-agent-core": "file:/tmp/pi-tarballs/earendil-works-pi-agent-core-0.78.1.tgz",
    "@earendil-works/pi-ai": "file:/tmp/pi-tarballs/earendil-works-pi-ai-0.78.1.tgz",
    "@earendil-works/pi-coding-agent": "file:/tmp/pi-tarballs/earendil-works-pi-coding-agent-0.78.1.tgz",
    "@earendil-works/pi-tui": "file:/tmp/pi-tarballs/earendil-works-pi-tui-0.78.1.tgz",
    "@sinclair/typebox": "^0.34.0",
    "express": "^4.19.2",
    "undici": "^6.20.0"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.5.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0",
    "vitest": "^2.1.0"
  }
}
