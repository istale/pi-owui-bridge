# pi-owui-bridge env. Copy to .env and fill in.

# --- where bridge forwards model calls (the bridge's "hub" hop) ---
AOH_HUB_BASE_URL=http://127.0.0.1:43180/v1
AOH_HUB_API_KEY=replace-me
AOH_MODEL_ID=MiniMax-M2
AOH_MODEL_PROVIDER=aoh-hub

# --- OWUI tool service the extension calls ---
AOH_OWUI_BASE_URL=http://127.0.0.1:8080
AOH_PI_SHARED_SECRET=shared-with-owui

# --- filesystem the bridge + Pi both touch ---
AOH_OBSERVATION_DIR=~/.pi/observation
AOH_SKILLS_DIR=~/.aoh/skills

# --- where the Pi binary + bridge extension live ---
AOH_PI_CLI_PATH=/abs/path/pi/packages/coding-agent/dist/cli.js
AOH_PI_EXTENSION_PATH=/abs/path/pi-owui-bridge/extension/dist/owui-tools.js

# --- bridge process knobs ---
AOH_BRIDGE_PORT=19000
AOH_PI_IDLE_EVICT_MS=300000

# --- legacy names still accepted with a deprecation warning ---
# AOH_UPSTREAM_BASE_URL  → AOH_HUB_BASE_URL
# AOH_UPSTREAM_API_KEY   → AOH_HUB_API_KEY
# AOH_UPSTREAM_MODEL     → AOH_MODEL_ID
# AOH_UPSTREAM_PROVIDER  → AOH_MODEL_PROVIDER
